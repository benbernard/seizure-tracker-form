{
  "name": "next-example",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:setup && npm run dev:app",
    "dev:setup": "npm run ensure-env && docker compose up -d dynamodb && npm run wait-for-dynamodb && npm run create-tables",
    "ensure-env": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.json scripts/ensure-env.ts",
    "dev:down": "docker compose down",
    "dev:reset": "docker compose down -v && npm run dev:setup",
    "dev:app": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:debug": "next dev",
    "wait-for-dynamodb": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.json scripts/wait-for-dynamodb.ts",
    "db:seed": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.json scripts/seed-local-db.ts",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format . --write",
    "create-tables": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.json scripts/create-tables.ts",
    "create-default-patient": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.json scripts/create-default-patient.ts",
    "import-medication-changes": "ts-node -r tsconfig-paths/register -P scripts/tsconfig.json scripts/import-medication-changes.ts",
    "test": "jest",
    "test:ui": "jest --selectProjects ui",
    "test:e2e": "playwright test",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.744.0",
    "@aws-sdk/lib-dynamodb": "^3.744.0",
    "@clerk/nextjs": "^6.12.0",
    "@tanstack/react-query": "^5.66.0",
    "@types/luxon": "^3.4.2",
    "@types/papaparse": "^5.3.15",
    "axios": "^1.6.7",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.475.0",
    "luxon": "^3.5.0",
    "next": "^15.5.21",
    "papaparse": "^5.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^5.0.0",
    "react-toastify": "^10.0.4",
    "recharts": "^2.15.1",
    "swr": "^2.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@clerk/testing": "^2.2.10",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
